{
  "name": "chaos-maker-docs",
  "version": "0.4.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "generate:versions": "node scripts/build-versioned-docs.mjs",
    "generate:versions:dev": "node scripts/build-versioned-docs.mjs --dev",
    "predev": "pnpm run generate:versions:dev",
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "prebuild": "pnpm run generate:versions",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.0",
    "astro": "^6.0.0"
  }
}
