{
  "name": "chaos-maker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A lightweight toolkit for injecting chaos into web applications",
  "scripts": {
    "lint": "eslint .",
    "build:core": "pnpm --filter @chaos-maker/core build",
    "build:playwright": "pnpm --filter @chaos-maker/playwright build",
    "build:cypress": "pnpm --filter @chaos-maker/cypress build",
    "build": "pnpm build:core && pnpm build:playwright && pnpm build:cypress",
    "dev:core": "pnpm --filter @chaos-maker/core dev",
    "test": "pnpm --filter @chaos-maker/core test",
    "test:playwright": "pnpm --filter e2e-tests-playwright exec playwright test",
    "test:cypress": "pnpm --filter e2e-tests-cypress exec cypress run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "eslint": "^9.39.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cypress"
    ],
    "overrides": {
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "picomatch@<2.3.2": "2.3.2",
      "flatted@<3.4.2": "3.4.2",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "js-yaml@>=4.0.0 <4.1.1": "4.1.1",
      "ajv@<6.14.0": "6.14.0",
      "qs@>=6.7.0 <=6.14.1": "6.14.2",
      "diff@>=4.0.0 <4.0.4": "4.0.4",
      "rollup@>=4.0.0 <4.59.0": "4.59.0"
    }
  },
  "packageManager": "pnpm@10.33.0",
  "lint-staged": {
    "**/*.ts": "eslint"
  }
}