{
  "name": "@chaos-maker/puppeteer",
  "version": "0.4.0",
  "type": "module",
  "description": "Puppeteer adapter for @chaos-maker/core — one-line chaos injection in Puppeteer tests",
  "keywords": [
    "chaos-engineering",
    "puppeteer",
    "headless-chrome",
    "testing",
    "e2e-testing",
    "resilience"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chaos-maker-dev/chaos-maker.git",
    "directory": "packages/puppeteer"
  },
  "homepage": "https://github.com/chaos-maker-dev/chaos-maker",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chaos-maker/core": "workspace:*"
  },
  "peerDependencies": {
    "puppeteer": ">=21.0.0",
    "puppeteer-core": ">=21.0.0"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    },
    "puppeteer-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "puppeteer": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  }
}
